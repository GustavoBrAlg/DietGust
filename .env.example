# Servidor local
PORT=3000

# Supabase (PostgreSQL Connection String)
# Exemplo: postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=your_supabase_postgres_connection_string_here

# JWT Secret para autenticação de sessões
JWT_SECRET=your_jwt_secret_key_here

# Provedor de IA (Vercel AI SDK)
# Necessário caso use o provedor OpenAI. Substitua pela chave apropriada do modelo escolhido.
OPENAI_API_KEY=your_openai_api_key_here
